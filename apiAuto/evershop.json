    {
      "name": "search",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const text = [\"Desk Pen Holder\", \"Ceramic Coffee Cup\"]\r",
              "\r",
              "function getRandomIntIntNumber(min, max) {\r",
              "    const  minCeiled = Math.ceil(min);\r",
              "    const  maxFloored = Math.floor(max);\r",
              "    return Math.floor(Math.random() * (maxFloored - minCeiled + 1)) + minCeiled;\r",
              "}\r",
              "\r",
              "const index = getRandomIntIntNumber(0, 1);\r",
              "const searchedText = text[index];\r",
              "pm.collectionVariables.set(\"searched_text\", searchedText);\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json(); // json code will show in console bar\r",
              "const searchedText = pm.collectionVariables.get(\"searched_text\");\r",
              "// console.log(responseBody);\r",
              "\r",
              "// test case for status code validation by arrow function\r",
              "pm.test(\"Validate status code is 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "})\r",
              "\r",
              "\r",
              "// test case for success value is true\r",
              "pm.test(\"Validte success valid is true\", () => {\r",
              "    pm.expect(responseBody.success).to.eql(true);\r",
              "})\r",
              "\r",
              "\r",
              "const items = responseBody.eContext.graphqlResponse.e35wux4h7ml3y45nz.products.items;\r",
              "for(let i=0; i<items.length; i++){\r",
              "    console.log(items[i].name);\r",
              "    pm.test(`Validate searched text within ${items[i].name}`,()=>{\r",
              "        pm.expect(items[i].name).to.contain(searchedText);\r",
              "    })\r",
              "}\r",
              "\r",
              "// product sku\r",
              "function getRandomIntIntNumber(min, max) {\r",
              "    const  minCeiled = Math.ceil(min);\r",
              "    const  maxFloored = Math.floor(max);\r",
              "    return Math.floor(Math.random() * (maxFloored - minCeiled + 1)) + minCeiled;\r",
              "}\r",
              "\r",
              "const index = getRandomIntIntNumber(1, items.length -1);\r",
              "const sku = items[index].sku;\r",
              "console.log(`Product sku: ${sku}`);\r",
              "pm.collectionVariables.set(\"product_sku\", sku);\r",
              "\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
